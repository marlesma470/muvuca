                pass
            sys.exit(0)
        debug_print("Credenciais OK.")
        
        # Loop de grupos
        while True:
            debug_print("Abrindo seleção de grupo...")
            result_group, group_dialog = abrir_dialogo_com_fallback(GroupSelectionDialog, timeout_ms=20000)
            if result_group != QDialog.Accepted:
                debug_print("Grupo cancelado. Encerrando.")
