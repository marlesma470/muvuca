    try:
        os.makedirs(appdata, exist_ok=True)
        test = os.path.join(appdata, 'test.tmp')
        with open(test, 'w') as f:
            f.write('test')
        os.remove(test)
        debug_print(f"Pasta {appdata} gravável.")
    except Exception as e:
        debug_print(f"ERRO: {appdata} não gravável: {e}")
        return False
    
    logs = os.path.join(os.getcwd(), 'Logs')
    try:
        os.makedirs(logs, exist_ok=True)
        test = os.path.join(logs, 'test.tmp')
        with open(test, 'w') as f:
