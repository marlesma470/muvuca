# ============================================================
# DETECTAR SE ESTÁ EM UMA PASTA DE REDE
# ============================================================
def is_network_path(path):
    """Verifica se o caminho é uma pasta de rede (UNC ou mapeada)."""
    try:
        # Verifica se é UNC
        if path.startswith('\\\\') or path.startswith('//'):
            return True
        # Verifica se é unidade mapeada (Windows)
        if sys.platform == 'win32':
            import ctypes.wintypes
            drive = os.path.splitdrive(path)[0]
            if drive:
                # Verifica o tipo de unidade
                drive_type = ctypes.windll.kernel32.GetDriveTypeW(drive + '\\')
                # DRIVE_REMOTE = 4
                if drive_type == 4:
                    return True
        return False
    except:
        return False

