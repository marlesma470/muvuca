# FUNÇÃO PARA FORÇAR JANELA VISÍVEL (COM DELAY)
# ============================================================
def abrir_dialogo_com_garantia(dialog_class, *args, **kwargs):
    nome_classe = dialog_class.__name__
    debug_print(f"-> Abrindo {nome_classe} com garantia...")
    
    try:
        debug_print(f"Criando instância de {nome_classe}")
        dialog = dialog_class(*args, **kwargs)
        debug_print(f"Instância criada: {dialog}")
        
        # Configurar janela
        dialog.setWindowFlags(Qt.Window | Qt.WindowStaysOnTopHint)
        dialog.setModal(True)
        
        # Centralizar
        screen = QApplication.primaryScreen().availableGeometry()
        x = screen.x() + (screen.width() - dialog.width()) // 2
        y = screen.y() + (screen.height() - dialog.height()) // 2
        dialog.move(x, y)
        debug_print(f"Posicionado em ({x}, {y})")
        
        # Mostrar com delay (100ms para processamento)
        dialog.show()
        dialog.raise_()
        dialog.activateWindow()
        QApplication.processEvents()
        debug_print("show() e raise_() chamados.")
        
        # Timer de segurança: após 500ms, tentar novamente se não visível
        def verificar_visibilidade():
            if not dialog.isVisible():
                debug_print("Janela não visível após 500ms. Reaplicando show()...")
                dialog.show()
                dialog.raise_()
                QApplication.processEvents()
        
        QTimer.singleShot(500, verificar_visibilidade)
        
        # Keep-alive timer (mantém no topo)
        def manter_top():
            if dialog.isVisible():
                dialog.raise_()
                dialog.activateWindow()
        
        timer = QTimer()
        timer.timeout.connect(manter_top)
        timer.start(200)  # a cada 200ms
        
        debug_print(f"Chamando exec() em {nome_classe}...")
        result = dialog.exec()
        timer.stop()
        debug_print(f"exec() retornou {result} para {nome_classe}")
        return result, dialog
        
    except Exception as e:
        debug_print(f"EXCEÇÃO em {nome_classe}: {str(e)}")
        debug_print(traceback.format_exc())
        try:
            QMessageBox.critical(None, f"Erro em {nome_classe}", str(e))
        except:
            pass
        return QDialog.Rejected, None


