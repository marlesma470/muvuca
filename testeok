    except Exception as e:
        debug_print(f"Erro ao configurar logger: {e}")
    
    try:
        verificar_permissoes()
        
        debug_print("Criando QApplication...")
        # Forçar o uso do plugin Windows (evita problemas de plataforma em RDP)
        os.environ["QT_QPA_PLATFORM"] = "windows"
        debug_print("QT_QPA_PLATFORM=windows definido.")
        
        app = QApplication(sys.argv)
        debug_print(f"QApplication criada.")
        
        # Usar software renderer para evitar problemas em terminais remotos
        app.setAttribute(Qt.AA_UseSoftwareOpenGL)
        debug_print("AA_UseSoftwareOpenGL aplicado.")
        
        # Diagnosticar telas
        diagnosticar_telas()
        
        # Ícone
