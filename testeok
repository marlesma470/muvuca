                   f"disponível={avail.x()},{avail.y()} {avail.width()}x{avail.height()}")
    if not screens:
        debug_print("NENHUMA TELA ENCONTRADA!")


# ============================================================
# FUNÇÃO PARA FORÇAR VISIBILIDADE COM FALLBACK
# ============================================================
def forcar_janela_visivel(dialog, nome_classe, tentativas=5):
    """Força a janela a aparecer usando várias técnicas, com fallback."""
    debug_print(f"Forçando visibilidade de {nome_classe}...")
    
    # Remover flags problemáticas
    dialog.setWindowFlags(Qt.Window | Qt.WindowStaysOnTopHint)
    dialog.setModal(True)
    
    # Posicionar no centro da tela primária (absoluto)
    screen = QApplication.primaryScreen().availableGeometry()
    x = screen.x() + (screen.width() - dialog.width()) // 2
    y = screen.y() + (screen.height() - dialog.height()) // 2
    if x < 0 or y < 0:
        debug_print(f"Coordenadas negativas ({x}, {y}). Forçando para (0,0)...")
        x = max(0, x)
        y = max(0, y)
    dialog.move(x, y)
    debug_print(f"Posicionado em ({x}, {y})")
    
    # Forçar show() e processar eventos
    for i in range(tentativas):
        dialog.show()
        dialog.raise_()
        dialog.activateWindow()
        QApplication.processEvents()
        time.sleep(0.1)
        if dialog.isVisible():
            debug_print(f"{nome_classe} visível (tentativa {i+1}).")
            break
        debug_print(f"Tentativa {i+1}: não visível.")
    
    # Se não visível, tentar showMaximized() + showNormal()
    if not dialog.isVisible():
        debug_print("Não visível. Tentando showMaximized() + showNormal()...")
        dialog.showMaximized()
        QApplication.processEvents()
        time.sleep(0.2)
        dialog.showNormal()
        QApplication.processEvents()
        if dialog.isVisible():
            debug_print(f"{nome_classe} visível após maximizar/restaurar.")
    
    # Se ainda não visível, tentar mover para (0,0)
    if not dialog.isVisible():
        debug_print("Ainda não visível. Movendo para (0,0)...")
        dialog.move(0, 0)
        dialog.show()
        QApplication.processEvents()
        time.sleep(0.2)
    
    # Verificar novamente
    if dialog.isVisible():
        debug_print(f"{nome_classe} visível com sucesso.")
        return True
    else:
        debug_print(f"CRÍTICO: {nome_classe} NÃO está visível após todas as tentativas.")
        return False


# ============================================================
# FUNÇÃO PARA ABRIR DIÁLOGO COM TIMEOUT E FALLBACK
# ============================================================
def abrir_dialogo_com_fallback(dialog_class, timeout_ms=30000, *args, **kwargs):
    """
    Tenta abrir o diálogo. Se falhar, oferece fallback ao usuário.
    Retorna (resultado, instância).
    """
    nome_classe = dialog_class.__name__
    debug_print(f"-> Abrindo {nome_classe} com fallback...")
    
    try:
        debug_print(f"Criando instância de {nome_classe}")
        dialog = dialog_class(*args, **kwargs)
        debug_print(f"Instância criada: {dialog}")
        
        # Forçar visibilidade
        if not forcar_janela_visivel(dialog, nome_classe):
            debug_print(f"Falha ao forçar visibilidade de {nome_classe}. Oferecendo fallback ao usuário.")
            # Mostrar mensagem de erro e oferecer opções
            msg = QMessageBox()
            msg.setWindowFlags(Qt.WindowStaysOnTopHint)
            msg.setIcon(QMessageBox.Warning)
            msg.setWindowTitle("Erro de exibição")
            msg.setText(f"Não foi possível exibir a janela '{nome_classe}'.\n"
                       f"Isso pode ocorrer em ambientes de rede ou RDP.\n\n"
                       f"O que você deseja fazer?")
            btn_continuar = msg.addButton("Continuar sem esta janela (fallback)", QMessageBox.AcceptRole)
            btn_sair = msg.addButton("Sair", QMessageBox.RejectRole)
            msg.exec()
            
            if msg.clickedButton() == btn_continuar:
                debug_print("Usuário optou por continuar com fallback.")
                # Retornamos Rejected, mas com um flag especial
                return QDialog.Rejected, None
            else:
                debug_print("Usuário optou por sair.")
                return QDialog.Rejected, None
        
        # Criar timer de timeout
        debug_print(f"Iniciando timeout de {timeout_ms}ms para {nome_classe}...")
        dialogo_fechado = False
        resultado = QDialog.Rejected
        
        def timeout_handler():
            nonlocal dialogo_fechado
            if not dialogo_fechado and dialog.isVisible():
                debug_print(f"TIMEOUT: {nome_classe} não respondeu em {timeout_ms}ms. Fechando diálogo.")
                dialogo_fechado = True
                dialog.close()
                QApplication.processEvents()
        
        timer = QTimer()
        timer.setSingleShot(True)
        timer.timeout.connect(timeout_handler)
        timer.start(timeout_ms)
        
        # Timer para manter a janela no topo
        def manter_top():
            if dialog.isVisible():
                dialog.raise_()
                dialog.activateWindow()
        
        timer_top = QTimer()
        timer_top.timeout.connect(manter_top)
        timer_top.start(300)
        
        debug_print(f"Chamando exec() em {nome_classe}...")
        result = dialog.exec()
        timer.stop()
        timer_top.stop()
        
        debug_print(f"exec() retornou {result} para {nome_classe}")
        
        if result == QDialog.Accepted:
            return result, dialog
        else:
            return QDialog.Rejected, dialog
        
    except Exception as e:
        debug_print(f"EXCEÇÃO em {nome_classe}: {str(e)}")
        debug_print(traceback.format_exc())
        try:
            QMessageBox.critical(None, f"Erro em {nome_classe}", str(e))
        except:
            pass
        return QDialog.Rejected, None


