# FUNÇÃO PARA COPIAR EXECUTÁVEL PARA LOCAL E REINICIAR
# ============================================================
def relancar_localmente():
    """Copia o executável para uma pasta temporária local e o reinicia."""
    debug_print("=== RELANÇAMENTO LOCAL ===")
    try:
        # Pasta temporária local
        temp_dir = os.path.join(os.environ.get('TEMP', tempfile.gettempdir()), 'AutomacaoCustodia_Local')
        os.makedirs(temp_dir, exist_ok=True)
        debug_print(f"Pasta temporária local: {temp_dir}")
        
        # Caminho do executável atual
        current_exe = sys.executable if getattr(sys, 'frozen', False) else __file__
        debug_print(f"Executável atual: {current_exe}")
        
        if not os.path.exists(current_exe):
            debug_print("Executável não encontrado.")
            return False
        
        # Copiar arquivos necessários
        dest_exe = os.path.join(temp_dir, os.path.basename(current_exe))
        debug_print(f"Copiando para: {dest_exe}")
        
        # Se for um .exe (PyInstaller), copiar apenas ele e os recursos
        if getattr(sys, 'frozen', False):
            # Copiar o .exe
            shutil.copy2(current_exe, dest_exe)
            # Copiar arquivos auxiliares (GIFs, ícone, etc.)
            for ext in ['.gif', '.ico']:
                for file in os.listdir(os.path.dirname(current_exe)):
                    if file.endswith(ext):
                        src = os.path.join(os.path.dirname(current_exe), file)
                        dst = os.path.join(temp_dir, file)
                        shutil.copy2(src, dst)
                        debug_print(f"Copiado: {file}")
        else:
            # Se for script Python, copiar tudo (simplificado)
            src_dir = os.path.dirname(current_exe)
            for item in os.listdir(src_dir):
                src = os.path.join(src_dir, item)
                dst = os.path.join(temp_dir, item)
                if os.path.isdir(src):
                    shutil.copytree(src, dst, ignore_dangling_symlinks=True, ignore=shutil.ignore_patterns('__pycache__', '*.pyc'))
                else:
                    shutil.copy2(src, dst)
            debug_print("Código copiado para local.")
        
        # Executar o novo processo
        debug_print(f"Iniciando processo local: {dest_exe}")
        if getattr(sys, 'frozen', False):
            subprocess.Popen([dest_exe], shell=True)
        else:
            subprocess.Popen([sys.executable, dest_exe], shell=True)
        
        debug_print("Processo local iniciado. Encerrando instância atual.")
        return True
    except Exception as e:
        debug_print(f"Erro ao relançar localmente: {e}")
        return False

