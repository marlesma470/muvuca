#!/usr/bin/env python
# -*- coding: utf-8 -*-

"""
Script para gerar o executável do sistema usando PyInstaller.
O EdgeDriver não é mais incluído, pois é baixado na primeira execução
e armazenado na pasta de dados do usuário (%APPDATA%).
"""

import subprocess
import sys
import os
import importlib.util

def instalar_pyinstaller():
    if importlib.util.find_spec("PyInstaller") is not None:
        print("✅ PyInstaller já está instalado.")
        return
    
    print("📦 PyInstaller não encontrado. Instalando...")
    try:
        subprocess.check_call([sys.executable, "-m", "pip", "install", "pyinstaller"])
        print("✅ PyInstaller instalado com sucesso.")
    except subprocess.CalledProcessError as e:
        print(f"❌ Erro ao instalar PyInstaller: {e}")
        sys.exit(1)

def gerar_executavel():
    print("\n🚀 Gerando executável...")
    
    hidden_imports = [
        "PySide6",
        "selenium",
        "webdriver_manager",
        "beautifulsoup4",
        "requests",
        "pandas",
        "openpyxl",
        "pywin32",
        "cryptography",
        "sqlalchemy",
        "apscheduler"
    ]
    
    cmd = [
        sys.executable, "-m", "PyInstaller",
        "--onefile",
        "--windowed",
        "--name", "AutomacaoCustodia",
        "--add-data", "src;src",
        # REMOVIDO: "--add-data", "msedgedriver.exe;.",
        "--clean",
        "--noconfirm"
    ]
    
    for mod in hidden_imports:
        cmd.extend(["--hidden-import", mod])
    
    cmd.append("main.py")
    
    try:
        subprocess.check_call(cmd)
        print("\n✅ Executável gerado com sucesso!")
        exe_path = os.path.join("dist", "AutomacaoCustodia.exe")
        print(f"📁 Localização: {os.path.abspath(exe_path)}")
                
    except subprocess.CalledProcessError as e:
        print(f"\n❌ Erro ao gerar executável: {e}")
        sys.exit(1)
    except FileNotFoundError:
        print("\n❌ PyInstaller não encontrado mesmo após instalação.")
        sys.exit(1)

def main():
    print("=== Build do Sistema de Automação (sem driver embutido) ===\n")
    print(f"🐍 Versão Python: {sys.version}")
    print(f"💻 Sistema Operacional: {sys.platform}")
    print()
    
    instalar_pyinstaller()
    gerar_executavel()
    
    print("\n🎉 Pronto! O executável está na pasta 'dist'.")
    print("📌 O usuário deve ter o Microsoft Edge instalado.")
    print("📌 Na primeira execução, clique em 'Atualizar Sistema' para baixar o EdgeDriver.")

if __name__ == "__main__":
    main()
