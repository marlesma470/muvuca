# ============================================================
# INSTALADOR AUTO-EXTRAÍVEL (gerado em 2026-06-30 13:38:04)
# ============================================================

Set-ExecutionPolicy -Scope Process -ExecutionPolicy Bypass -Force

function Show-Progress {
    param([int]$c, [int]$t, [string]$act="Processando", [string]$st="")
    if ($t -le 0) { return }
    $p = [int]($c / $t * 100)
    Write-Progress -Activity $act -Status $st -PercentComplete $p -CurrentOperation "$c de $t"
}

try {
    $scriptPath = Split-Path -Parent $MyInvocation.MyCommand.Path
    Set-Location $scriptPath
    Write-Host "Instalando em: $scriptPath" -ForegroundColor Yellow

    # Criar pastas
    $folders = @(
        "src"
        "src/generators"
        "src/gui"
    )
    $totalFolders = $folders.Count
    for ($i=0; $i -lt $totalFolders; $i++) {
        $f = $folders[$i]
        if (-not (Test-Path $f)) { New-Item -ItemType Directory -Path $f -Force | Out-Null }
        Show-Progress -c ($i+1) -t $totalFolders -act "Criando pastas" -st $f
    }
    Write-Host "Pastas criadas." -ForegroundColor Green

    # Pasta de dados do usuário
    $appData = Join-Path $env:APPDATA "AutomacaoCustodia"
    if (-not (Test-Path $appData)) { New-Item -ItemType Directory -Path $appData -Force | Out-Null }
    Write-Host "Pasta de dados: $appData" -ForegroundColor Yellow

    Write-Host "`nExtraindo arquivos..." -ForegroundColor Cyan

    # Dados codificados (cada linha: caminho|base64)
    $data = @'
agendamentos_E1.txt|
analisesistema.ps1|
AutomacaoCustodia.spec|
build.py|
gerar_instalador.py|
grupos.txt|RTENCkUyDQo=
instalar_dependencias.py|
main.py|
requirements.txt|
run.py|
src/browser_config.py|
src/browser_manager.py|
src/credential_service.py|
src/database.py|
src/executor.py|
src/logger.py|
src/models.py|
src/sicredi_colors.py|
src/theme_preference.py|
src/update_service.py|
src/__init__.py|
src/generators/gerador_powershell.py|
src/generators/gerador_vba.py|
src/gui/atualizacao_dialog.py|
src/gui/browser_settings_dialog.py|
src/gui/builder_dialog.py|
src/gui/chat_side.py|
src/gui/credential_dialog.py|
src/gui/detail_dialog.py|
src/gui/group_selection.py|
src/gui/html_selector.py|
src/gui/main_window.py|
src/gui/passo_builder.py|
src/gui/passo_builder_dialog.py|
src/gui/revisao_dialog.py|
src/gui/__init__.py|
'@

    $lines = $data -split "`r`n" | Where-Object { $_ -ne "" }
    $totalFiles = $lines.Count
    $i = 0
    foreach ($line in $lines) {
        $i++
        $parts = $line -split '\|', 2
        if ($parts.Count -ne 2) { continue }
        $path = $parts[0]
        $b64 = $parts[1]
        Show-Progress -c $i -t $totalFiles -act "Extraindo" -st $path
        $bytes = [Convert]::FromBase64String($b64)
        [System.IO.File]::WriteAllBytes($path, $bytes)
        Write-Host "OK $path" -ForegroundColor Green
    }

    Write-Host "`nInstalando dependências Python..." -ForegroundColor Cyan

    # ============================================================
    # 1. DETECÇÃO DO PYTHON (ROBUSTA)
    # ============================================================
    $pythonCmd = $null
    $pythonExe = $null

    # Tentar 'py' (lançador do Windows)
    if (Get-Command py -ErrorAction SilentlyContinue) {
        $pythonCmd = "py"
        $pythonExe = "py"
        Write-Host "Python encontrado via 'py'" -ForegroundColor Green
    }
    # Tentar 'python'
    elseif (Get-Command python -ErrorAction SilentlyContinue) {
        $pythonCmd = "python"
        $pythonExe = "python"
        Write-Host "Python encontrado via 'python'" -ForegroundColor Green
    }
    # Tentar caminhos comuns (último recurso)
    else {
        $commonPaths = @(
            "$env:LOCALAPPDATA\Programs\Python\Python3*\python.exe",
            "$env:LOCALAPPDATA\Programs\Python\Python*\python.exe",
            "$env:ProgramFiles\Python3*\python.exe",
            "$env:ProgramFiles\Python*\python.exe",
            "$env:ProgramFiles (x86)\Python3*\python.exe",
            "$env:ProgramFiles (x86)\Python*\python.exe"
        )
        foreach ($pattern in $commonPaths) {
            $found = Get-ChildItem -Path $pattern -ErrorAction SilentlyContinue | Select-Object -First 1
            if ($found) {
                $pythonExe = $found.FullName
                $pythonCmd = $pythonExe
                Write-Host "Python encontrado em: $pythonExe" -ForegroundColor Green
                break
            }
        }
    }

    if (-not $pythonCmd) {
        Write-Host "Python não encontrado!" -ForegroundColor Red
        Write-Host "   Baixe e instale o Python de: https://www.python.org/downloads/" -ForegroundColor Yellow
        Write-Host "   Durante a instalação, marque a opção 'Add Python to PATH'." -ForegroundColor Yellow
        Write-Host "`nApós instalar, execute este instalador novamente." -ForegroundColor Yellow
        throw "Python não encontrado"
    }

    Write-Host "Usando Python: $pythonCmd" -ForegroundColor Green

    # ============================================================
    # 2. VERIFICAR / INSTALAR PIP
    # ============================================================
    $pipCheck = & "$pythonCmd" -m pip --version 2>&1
    if ($LASTEXITCODE -ne 0) {
        Write-Host "Pip não encontrado. Tentando instalar o pip..." -ForegroundColor Yellow
        & "$pythonCmd" -m ensurepip --upgrade 2>&1
        if ($LASTEXITCODE -ne 0) {
            Write-Host "Falha ao instalar pip automaticamente." -ForegroundColor Red
            Write-Host "Execute manualmente no terminal (como administrador):" -ForegroundColor Yellow
            Write-Host "   `"$pythonCmd`" -m ensurepip --upgrade" -ForegroundColor Cyan
            throw "pip não disponível"
        }
        Write-Host "Pip instalado com sucesso." -ForegroundColor Green
    }

    # ============================================================
    # 3. INSTALAR DEPENDÊNCIAS
    # ============================================================
    Write-Host "Instalando dependências (pode demorar alguns minutos)..." -ForegroundColor Yellow

    if (-not (Test-Path "requirements.txt")) {
        Write-Host "Arquivo requirements.txt não encontrado!" -ForegroundColor Red
        Write-Host "Verifique se o arquivo foi extraído corretamente." -ForegroundColor Yellow
        throw "requirements.txt não encontrado"
    }

    $pipArgs = @("-m", "pip", "install", "--no-cache-dir", "-r", "requirements.txt")
    $installResult = & "$pythonCmd" $pipArgs 2>&1

    if ($LASTEXITCODE -eq 0) {
        Write-Host "Dependências instaladas com sucesso!" -ForegroundColor Green
    } else {
        Write-Host "Falha ao instalar as dependências automaticamente." -ForegroundColor Red
        Write-Host "Erro: $installResult" -ForegroundColor Red

        Write-Host "`nPara instalar manualmente, execute o script de instalação incluso:" -ForegroundColor Yellow
        Write-Host "   `"$pythonCmd`" instalar_dependencias.py" -ForegroundColor Cyan
        Write-Host "`nOu, se preferir via pip diretamente:" -ForegroundColor Yellow
        Write-Host "   `"$pythonCmd`" -m pip install --no-cache-dir -r requirements.txt" -ForegroundColor Cyan

        throw "Falha na instalação das dependências"
    }

    Write-Host "`nInstalação concluída!" -ForegroundColor Green
    Write-Host "Execute o sistema com: `"$pythonCmd`" main.py" -ForegroundColor Yellow

} catch {
    Write-Host "`nERRO: $_" -ForegroundColor Red
    Write-Host "`nCaso o problema persista, verifique a instalação do Python e tente novamente." -ForegroundColor Yellow
    Write-Host "Recomenda-se instalar as dependências manualmente via terminal do VSCode." -ForegroundColor Yellow
}

Write-Host "`nPressione qualquer tecla para sair..."
$null = $Host.UI.RawUI.ReadKey("NoEcho,IncludeKeyDown")
