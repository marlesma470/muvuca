        self._filtrar_agendamentos()
        self.agendamentos_atualizados.emit()

    def _marcar_expirados_na_inicializacao(self):
        agora = datetime.now()
        alterados = 0
        with get_session() as session:
            for ag in self.agendamentos_completos:
                if ag.proxima_execucao <= agora and ag.status not in ("Executado", "Falha", "Expirado"):
                    diff = (agora - ag.proxima_execucao).total_seconds()
                    if diff > 10:
                        logger.info(f"Marcando como expirado na inicialização: {ag.nome_script} (atraso de {diff:.1f}s)")
                        ag.status = "Expirado"
                        ag.resultado_execucao = f"EXPIROU: Sistema iniciado após o horário agendado ({ag.proxima_execucao.strftime('%H:%M:%S')})."
                        ag.atualizar_proxima_execucao()
                        salvar_agendamento(session, ag)
                        alterados += 1
                    else:
                        logger.info(f"Agendamento {ag.nome_script} com atraso pequeno ({diff:.1f}s) na inicialização. Tentando executar.")
                        if ag.ativo and os.path.exists(ag.script_path):
                            self._executar_automacao(ag)
        if alterados > 0:
            logger.info(f"Marcados {alterados} agendamentos como expirados na inicialização.")
            self._carregar_agendamentos()

    def _resetar_agendamentos_antigos(self):
        agora = datetime.now()
        limite = agora - timedelta(hours=1)
        alterados = 0
        with get_session() as session:
            for ag in self.agendamentos_completos:
                if ag.ultima_execucao < limite and ag.status in ("Executado", "Falha"):
                    logger.info(f"Resetando agendamento antigo: {ag.nome_script} (status: {ag.status}, última execução: {ag.ultima_execucao})")
                    ag.status = "Aguardando"
                    ag.resultado_execucao = ""
                    ag.atualizar_proxima_execucao()
                    salvar_agendamento(session, ag)
                    alterados += 1
        if alterados > 0:
            logger.info(f"Resetados {alterados} agendamentos antigos.")
            self._carregar_agendamentos()

    def _filtrar_agendamentos(self):
        self.filtro_texto = self.txt_pesquisa.text().strip().lower()
        self.filtro_periodo = self.cmb_filtro.currentText()
        self._atualizar_tabela()

    def _obter_filtrados(self) -> List[Agendamento]:
        if not self.agendamentos_completos:
            return []

        resultado = self.agendamentos_completos[:]

        if self.filtro_texto:
            texto_busca = self.filtro_texto.lower()
            filtrados = []
            for ag in resultado:
                prox_str = ag.proxima_execucao.strftime("%d/%m/%Y %H:%M:%S") if ag.proxima_execucao else ""
                campos = [
                    ag.grupo_origem.lower(),
                    ag.nome_script.lower(),
                    prox_str.lower(),
                    ag.status.lower(),
                    ag.resultado_execucao.lower()
                ]
                if any(texto_busca in campo for campo in campos):
                    filtrados.append(ag)
            resultado = filtrados

        hoje = datetime.now().date()
        periodo = self.filtro_periodo

        if periodo == "Hoje":
            resultado = [a for a in resultado if a.proxima_execucao.date() == hoje]
        elif periodo == "Amanhã":
            amanha = hoje + timedelta(days=1)
            resultado = [a for a in resultado if a.proxima_execucao.date() == amanha]
        elif periodo == "Semana atual":
            inicio_semana = hoje - timedelta(days=hoje.weekday())
            fim_semana = inicio_semana + timedelta(days=6)
            resultado = [a for a in resultado if inicio_semana <= a.proxima_execucao.date() <= fim_semana]
        elif periodo == "Quinzena atual":
            if hoje.day <= 15:
                inicio = hoje.replace(day=1)
                fim = hoje.replace(day=15)
            else:
                inicio = hoje.replace(day=16)
                if hoje.month == 12:
                    fim = hoje.replace(year=hoje.year+1, month=1, day=1) - timedelta(days=1)
                else:
                    fim = hoje.replace(month=hoje.month+1, day=1) - timedelta(days=1)
            resultado = [a for a in resultado if inicio <= a.proxima_execucao.date() <= fim]
        elif periodo == "Próxima quinzena":
            inicio = hoje + timedelta(days=1)
            fim = hoje + timedelta(days=15)
            resultado = [a for a in resultado if inicio <= a.proxima_execucao.date() <= fim]
        elif periodo == "Mês atual":
            inicio = hoje.replace(day=1)
            if hoje.month == 12:
                fim = hoje.replace(year=hoje.year+1, month=1, day=1) - timedelta(days=1)
            else:
                fim = hoje.replace(month=hoje.month+1, day=1) - timedelta(days=1)
            resultado = [a for a in resultado if inicio <= a.proxima_execucao.date() <= fim]
        elif periodo == "Nesse ano":
            inicio = hoje.replace(month=1, day=1)
            fim = hoje.replace(month=12, day=31)
            resultado = [a for a in resultado if inicio <= a.proxima_execucao.date() <= fim]
        elif periodo == "Ano que vem":
            inicio = hoje.replace(year=hoje.year+1, month=1, day=1)
            fim = hoje.replace(year=hoje.year+1, month=12, day=31)
            resultado = [a for a in resultado if inicio <= a.proxima_execucao.date() <= fim]
        elif periodo == "Futuras":
            resultado = [a for a in resultado if a.proxima_execucao.date() > hoje]
        elif periodo == "Expiradas":
            resultado = [a for a in resultado if a.status == "Expirado"]

        return resultado

    @Slot()
    def _atualizar_tabela(self):
        self.agendamentos_exibidos = self._obter_filtrados()
        self.table.agendamentos = self.agendamentos_exibidos
        self.table.setRowCount(len(self.agendamentos_exibidos))

        for row, ag in enumerate(self.agendamentos_exibidos):
            self._set_item(row, 0, ag.grupo_origem)
            self._set_item(row, 1, ag.nome_script)
            self._set_item(row, 2, ag.proxima_execucao.strftime("%d/%m/%Y %H:%M:%S"))
            item_status = QTableWidgetItem(ag.status)
            if ag.status == "Executado":
                item_status.setBackground(QColor(144, 238, 144))
            elif ag.status in ("Falha", "Expirado"):
                item_status.setBackground(QColor(255, 182, 193))
            elif ag.status == "Executando":
                item_status.setBackground(QColor(173, 216, 230))
            else:
                item_status.setBackground(QColor(255, 255, 200))
            self.table.setItem(row, 3, item_status)
            self.table.setItem(row, 4, QTableWidgetItem(""))

            # Retorno com data da última execução
            ret = ag.resultado_execucao or ""
            if ag.ultima_execucao and ret:
                if ag.ultima_execucao.year > 2000:
                    data_str = ag.ultima_execucao.strftime("%d/%m/%Y %H:%M")
                    ret = f"{data_str} - {ret}"
            item_retorno = QTableWidgetItem(ret)
            item_retorno.setToolTip(ret)
            self.table.setItem(row, 5, item_retorno)

        for row in range(self.table.rowCount()):
            self.table.setRowHeight(row, 35)

        self.lbl_status.setText(f"{len(self.agendamentos_exibidos)} automações exibidas (de {len(self.agendamentos_completos)})")
        self._aplicar_cores_tabela()

    def _set_item(self, row, col, text):
        existing = self.table.item(row, col)
        if existing:
            existing.setText(text)
        else:
            self.table.setItem(row, col, QTableWidgetItem(text))

    def _ordenar_tabela(self, col_idx: int):
        pass

    def _iniciar_timers(self):
        self.timer_segundo = QTimer()
        self.timer_segundo.timeout.connect(self._tick_relogio)
        self.timer_segundo.start(1000)

        self.timer_barra = QTimer()
        self.timer_barra.timeout.connect(self._atualizar_barras)
        self.timer_barra.start(1000)

        self.verificar_agendamentos_timer = QTimer()
        self.verificar_agendamentos_timer.timeout.connect(self._verificar_agendamentos)
        self.verificar_agendamentos_timer.start(1000)
        logger.info("Timers iniciados: relógio, barra e verificação a cada 1 segundo")

        QTimer.singleShot(2000, self._verificar_agendamentos)

    @Slot()
    def _tick_relogio(self):
        self._atualizar_relogio()

    @Slot()
    def _atualizar_barras(self):
        self.table.viewport().update()

    @Slot()
    def _verificar_agendamentos(self):
        agora = datetime.now()
        logger.info(f"Verificando agendamentos em {agora.strftime('%H:%M:%S.%f')[:-3]}")

        with get_session() as session:
            if self.eh_todos:
                self.agendamentos_completos = carregar_agendamentos(session, None)
            else:
                self.agendamentos_completos = carregar_agendamentos(session, self.grupo_selecionado)

        self._resetar_agendamentos_antigos()
        self.agendamentos_completos.sort(key=lambda x: x.proxima_execucao)

        para_executar = []

        for ag in self.agendamentos_completos:
            if not ag.ativo:
                continue
            if ag.status in ("Executando", "Expirado"):
                continue

            diff = (ag.proxima_execucao - agora).total_seconds()
            logger.info(f"  Agendamento '{ag.nome_script}': proxima_execucao={ag.proxima_execucao.strftime('%H:%M:%S')}, diff={diff:.3f}s, status={ag.status}")

            if diff > 2.0:
                continue

            if -2.0 <= diff <= 2.0:
                if os.path.exists(ag.script_path):
                    para_executar.append(ag)
                    logger.info(f"  -> Adicionado à lista de execução (diff={diff:.3f}s)")
                else:
                    logger.error(f"  -> Script não encontrado: {ag.script_path}")
                    ag.status = "Falha"
                    ag.resultado_execucao = f"FALHA - Script não encontrado: {ag.script_path}"
                    ag.ultima_execucao = agora
                    ag.atualizar_proxima_execucao()
                    with get_session() as session:
                        salvar_agendamento(session, ag)
                    self.agendamentos_atualizados.emit()
            else:
                logger.warning(f"  -> Atraso de {abs(diff):.3f}s > 2s. Marcando como expirado.")
                ag.status = "Expirado"
                ag.resultado_execucao = f"EXPIROU: Horário de execução passou (agendado para {ag.proxima_execucao.strftime('%H:%M:%S')})."
                ag.atualizar_proxima_execucao()
                with get_session() as session:
                    salvar_agendamento(session, ag)
                self.agendamentos_atualizados.emit()

        if para_executar:
            logger.info(f"Encontrados {len(para_executar)} agendamentos para executar agora (tolerância de 2s).")
            for ag in para_executar:
                self._executar_automacao(ag)
        else:
            logger.info("Nenhum agendamento pendente.")

    def _executar_automacao(self, ag: Agendamento):
        logger.info(f"=== _executar_automacao CHAMADO para {ag.nome_script} ===")
        if ag.nome_script in self.processos_em_execucao:
            logger.warning(f"Automação {ag.nome_script} já está em execução. Ignorando.")
            return

        if ag.status == "Executando":
            logger.warning(f"Status de {ag.nome_script} estava 'Executando'. Forçando para 'Aguardando'.")
            ag.status = "Aguardando"
            with get_session() as session:
                salvar_agendamento(session, ag)

        if not os.path.exists(ag.script_path):
            logger.error(f"Script não encontrado: {ag.script_path}")
            ag.status = "Falha"
            ag.resultado_execucao = f"FALHA - Script não encontrado: {ag.script_path}"
            ag.ultima_execucao = datetime.now()
            ag.atualizar_proxima_execucao()
            with get_session() as session:
                salvar_agendamento(session, ag)
            self.agendamentos_atualizados.emit()
            return

        logger.info(f"Iniciando execução de {ag.nome_script} (grupo {ag.grupo_origem})")
        ag.status = "Executando"
        ag.resultado_execucao = ""
        with get_session() as session:
            salvar_agendamento(session, ag)
        self.agendamentos_atualizados.emit()

        worker = ExecutorWorker(ag, ag.grupo_origem, headless=True)
        worker.finished.connect(
            lambda nome, sucesso, mensagem, logs: self.execucao_terminada.emit(nome, sucesso, mensagem, logs)
        )
        worker.finished.connect(worker.deleteLater)

        self._threads_em_execucao[ag.nome_script] = worker
        worker.finished.connect(lambda: self._threads_em_execucao.pop(ag.nome_script, None))

        self.processos_em_execucao.add(ag.nome_script)
        worker.start()
        logger.info(f"Thread iniciada para {ag.nome_script} (headless=True)")

    @Slot(str, bool, str, list)
    def _finalizar_execucao(self, nome: str, sucesso: bool, mensagem: str, logs: list):
        logger.info(f"Finalizando execução de {nome}: sucesso={sucesso}, mensagem={mensagem}")
        self.processos_em_execucao.discard(nome)

        with get_session() as session:
            ag = carregar_agendamento_por_nome(session, nome, self.grupo_selecionado if not self.eh_todos else None)
            if not ag:
                with get_session() as session2:
                    todos = carregar_agendamentos(session2, None)
                    for a in todos:
                        if a.nome_script == nome:
                            ag = a
                            break
                if not ag:
                    logger.warning(f"Agendamento {nome} não encontrado no banco.")
                    return

            ag.ultima_execucao = datetime.now()

            prefixo = "SUCESSO" if sucesso else "FALHA"
            if mensagem and mensagem.strip():
                ag.resultado_execucao = f"{prefixo} - {mensagem.strip()}"
            else:
                ag.resultado_execucao = prefixo

            ag.status = "Executado" if sucesso else "Falha"
            ag.atualizar_proxima_execucao()
            if ag.proxima_execucao <= datetime.now():
                ag.status = "Aguardando"

            salvar_agendamento(session, ag)

        for i, a in enumerate(self.agendamentos_completos):
            if a.nome_script == nome and a.grupo_origem == ag.grupo_origem:
                a.ultima_execucao = ag.ultima_execucao
                a.resultado_execucao = ag.resultado_execucao
                a.status = ag.status
                a.proxima_execucao = ag.proxima_execucao
                a.expirado = ag.expirado
                break

        self.agendamentos_atualizados.emit()

        if logs:
            self._salvar_logs_detalhados(nome, logs)

    def _salvar_logs_detalhados(self, nome: str, logs: list):
        try:
            log_dir = os.path.join(self.pasta_logs)
            os.makedirs(log_dir, exist_ok=True)
            log_file = os.path.join(log_dir, f"{nome}_{datetime.now().strftime('%Y%m%d_%H%M%S')}.log")
            usuario = os.environ.get('USERNAME', 'desconhecido')
            with open(log_file, 'w', encoding='utf-8') as f:
                f.write(f"=== LOGS DETALHADOS - {nome} ===\n")
                f.write(f"Data: {datetime.now().strftime('%d/%m/%Y %H:%M:%S')}\n")
                f.write(f"Usuario: {usuario}\n")
                f.write("=" * 50 + "\n")
                for log in logs:
                    passo = log.get("passo", 0)
                    acao = log.get("acao", "")
                    desc = log.get("descricao", "")
                    sucesso_log = log.get("sucesso", False)
                    erro = log.get("erro", "")
                    detalhes = log.get("detalhes", "")

                    f.write(f"[{passo}] {acao} - {desc} - {'SUCESSO' if sucesso_log else 'FALHA'}\n")
                    if detalhes:
                        f.write(f"    Saída do script:\n")
                        for linha in detalhes.strip().splitlines():
                            f.write(f"        {linha}\n")
                    if erro:
                        f.write(f"    Erro: {erro}\n")
                f.write("=" * 50 + "\n")
            logger.info(f"Logs detalhados salvos em: {log_file}")
        except Exception as e:
            logger.warning(f"Não foi possível salvar logs detalhados: {e}")

    def _abrir_detalhes(self, index):
        row = index.row()
        if row < 0 or row >= len(self.agendamentos_exibidos):
            return
        ag = self.agendamentos_exibidos[row]
        logger.info(f"Abrindo detalhes de {ag.nome_script}")

        dialog = AutomationDetailDialog(
            ag, ag.grupo_origem, self,
            on_execute=self._executar_automacao,
            on_edit=self._editar_automacao,
            on_delete=self._excluir_automacao,
            on_chat=self._abrir_chat_lateral
        )
        dialog.exec()

    def _editar_automacao(self, ag: Agendamento):
        logger.info(f"Editando automação {ag.nome_script}")
        dialog = EditarAutomacaoDialog(ag, ag.grupo_origem, self)
        if dialog.exec():
            logger.info("Edição salva, recarregando")
            self._carregar_agendamentos()

    def _excluir_automacao(self, ag: Agendamento):
        resposta = QMessageBox.question(
            self,
            "Confirmar exclusão",
            f"Excluir a automação '{ag.nome_script}' permanentemente?\n\n"
            "O arquivo .py também será removido da pasta Atividades.",
            QMessageBox.Yes | QMessageBox.No
        )
        if resposta == QMessageBox.Yes:
            logger.info(f"Excluindo automação {ag.nome_script}")
            if ag.script_path and os.path.exists(ag.script_path):
                try:
                    os.remove(ag.script_path)
                    logger.info(f"Script removido: {ag.script_path}")
                except Exception as e:
                    logger.warning(f"Não foi possível remover script {ag.script_path}: {e}")

            with get_session() as session:
                excluir_agendamento(session, ag.nome_script, ag.grupo_origem)
            self._carregar_agendamentos()

    def _abrir_chat_lateral(self, ag: Agendamento):
        if self.chat_lateral and not self.chat_lateral.isVisible():
            self.chat_lateral.close()
            self.chat_lateral = None
        if not self.chat_lateral:
            self.chat_lateral = ChatSideWindow(ag.grupo_origem, ag.nome_script, parent=self)
            self.chat_lateral.setWindowFlags(Qt.Window)
            self.chat_lateral.show()
        else:
            self.chat_lateral.raise_()
            self.chat_lateral.activateWindow()

    def _abrir_credenciais(self):
        from .credential_dialog import CredentialSetupDialog
        dlg = CredentialSetupDialog(self)
        dlg.exec()

    def _alternar_tema(self):
        ThemePreference.toggle_theme()
        self._aplicar_tema()
        self._aplicar_cores_tabela()

    def _aplicar_cores_tabela(self):
        is_dark = ThemePreference.is_dark()
        if is_dark:
            bg_alternate = QColor(45, 45, 50)
            bg_normal = QColor(30, 30, 35)
            text_color = QColor(255, 255, 255)
            header_bg = QColor(60, 60, 70)
            header_text = QColor(255, 255, 255)
            grid_color = QColor(70, 70, 80)
        else:
            bg_alternate = QColor(245, 245, 245)
            bg_normal = QColor(255, 255, 255)
            text_color = QColor(0, 0, 0)
            header_bg = QColor(230, 230, 235)
            header_text = QColor(0, 0, 0)
            grid_color = QColor(200, 200, 210)

        for row in range(self.table.rowCount()):
            for col in range(self.table.columnCount()):
                item = self.table.item(row, col)
                if item:
                    item.setBackground(bg_alternate if row % 2 else bg_normal)
                    item.setForeground(text_color)

        header = self.table.horizontalHeader()
        header.setStyleSheet(f"""
            QHeaderView::section {{
                background-color: {header_bg.name()};
                color: {header_text.name()};
                padding: 5px;
                border: 1px solid {grid_color.name()};
            }}
        """)

        self.table.setStyleSheet(f"""
            QTableWidget {{
                gridline-color: {grid_color.name()};
                alternate-background-color: {bg_alternate.name()};
            }}
        """)

    def closeEvent(self, event):
        logger.info("Iniciando fechamento da MainWindow...")
        if self.timer_segundo:
            self.timer_segundo.stop()
        if self.timer_barra:
            self.timer_barra.stop()
        if self.verificar_agendamentos_timer:
            self.verificar_agendamentos_timer.stop()

        for nome, thread in list(self._threads_em_execucao.items()):
            if thread.isRunning():
                logger.info(f"Aguardando término da thread {nome}...")
                if not thread.wait(10000):
                    logger.warning(f"Thread {nome} não terminou, forçando finalização.")
                    thread.terminate()
                    thread.wait()

        if self.chat_lateral:
            self.chat_lateral.close()
            self.chat_lateral = None

        event.accept()
        logger.info("MainWindow fechada.")

