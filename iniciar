@echo off
title Sistema de Automação (Leve)

:: Remove aspas extras do caminho
set "SCRIPT_DIR=%~dp0"
set "SCRIPT_DIR=%SCRIPT_DIR:~0,-1%"

:: Tenta usar pushd para mapear a UNC
pushd "%SCRIPT_DIR%" 2>nul
if errorlevel 1 (
    echo ERRO: Nao foi possivel acessar %SCRIPT_DIR%
    echo Tente mapear a unidade manualmente ou execute como administrador.
    pause
    exit /b 1
)

:: Agora o diretório atual é a unidade mapeada (ex: Z:)
set "PYTHON_DIR=%CD%\python-portable"
set "PYTHON_EXE=%PYTHON_DIR%\python.exe"

if not exist "%PYTHON_EXE%" (
    echo ERRO: Python nao encontrado em %PYTHON_EXE%
    popd
    pause
    exit /b 1
)

echo Executando sistema em %CD%...
"%PYTHON_EXE%" main.py

:: Volta para o diretório original
popd
pause
