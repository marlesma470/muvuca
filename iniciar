def preencher_otp(page, codigo):
    """
    Preenche o campo OTP com o código e clica em Entrar.
    """
    page.fill('#otp', codigo)
    page.click('#kc-login')
    # Aguarda o carregamento da página principal (ex: presença de "Extrato")
    page.wait_for_selector('a:has-text("Extrato")', timeout=60000)

def navegar_ate_custo_selic(page):
    """
    Clica em Extrato e depois em Custo Selic.
    """
    page.click('a:has-text("Extrato")')
    page.wait_for_selector('a[href*="custo-selic"]', timeout=30000)
    page.click('a[href*="custo-selic"]')
    # Aguarda o carregamento da página do Custo Selic
    page.wait_for_selector('button[title="Download"]', timeout=30000)

def acessar_asel_e_baixar(page):
    """
    Clica no item 'ASEL' e depois no botão de download.
    """
    # Localiza o elemento ASEL (div com classe e texto)
    asel = page.locator('div.itemNavegacao:has-text("ASEL")')
    asel.wait_for(timeout=30000)
    asel.click()
    # Aguarda a nova página carregar
    page.wait_for_selector('button[title="Download"]', timeout=30000)
    # Baixa o arquivo (segundo download)
    baixar_arquivo(page)

