# iniciar.ps1
$scriptPath = Split-Path -Parent $MyInvocation.MyCommand.Path
$pythonExe = Join-Path $scriptPath "python-portable\python.exe"
$mainPy = Join-Path $scriptPath "main.py"

if (-not (Test-Path $pythonExe)) {
    Write-Host "ERRO: Python nao encontrado em $pythonExe" -ForegroundColor Red
    Read-Host "Pressione Enter para sair"
    exit 1
}

Write-Host "Executando sistema a partir de: $scriptPath" -ForegroundColor Cyan
& $pythonExe $mainPy




@echo off
title Sistema de Automação (Leve)
powershell -ExecutionPolicy Bypass -File "%~dp0iniciar.ps1"
pause
