import json
import time
import os
import win32gui
import win32process
import psutil
from pynput import mouse, keyboard

STOP_KEY = keyboard.Key.esc

def listar_janelas():
    """Lista janelas visíveis com título, handle e PID do processo."""
    def callback(hwnd, hwnds):
        if win32gui.IsWindowVisible(hwnd):
            title = win32gui.GetWindowText(hwnd)
            if title:
                try:
                    _, pid = win32process.GetWindowThreadProcessId(hwnd)
                    proc = psutil.Process(pid)
                    nome = proc.name()
                except:
                    pid = 0
                    nome = "desconhecido"
                hwnds.append((hwnd, title, nome, pid))
        return True
    hwnds = []
    win32gui.EnumWindows(callback, hwnds)
    return hwnds

def escolher_janela(janelas):
    print("\nJanelas abertas encontradas:")
    for i, (hwnd, title, proc, pid) in enumerate(janelas):
        print("{}. {} (processo: {} | PID: {})".format(i+1, title, proc, pid))
    while True:
        try:
            opcao = input("Escolha o numero da janela para gravar: ").strip()
            idx = int(opcao) - 1
            if 0 <= idx < len(janelas):
                return janelas[idx]
            print("Opcao invalida.")
        except ValueError:
            print("Digite um numero valido.")

def get_desktop_path():
    return os.path.join(os.path.expanduser("~"), "Desktop")

def get_window_rect(hwnd):
    return win32gui.GetWindowRect(hwnd)

def is_point_inside_window(x, y, hwnd):
    if not hwnd:
        return False
    left, top, right, bottom = get_window_rect(hwnd)
    return left <= x <= right and top <= y <= bottom

def get_process_id_from_window(hwnd):
    """Retorna o PID do processo que possui a janela."""
    try:
        _, pid = win32process.GetWindowThreadProcessId(hwnd)
        return pid
    except:
        return 0

def main():
    print("="*60)
    print("GRAVADOR DE MACROS - COM SELECAO DE JANELA")
    print("="*60)

    janelas = listar_janelas()
    if not janelas:
        print("Nenhuma janela com titulo encontrada.")
        return

    hwnd, title, proc_name, pid = escolher_janela(janelas)
    left, top, right, bottom = get_window_rect(hwnd)
    print("Janela selecionada: '{}' (PID: {}, posicao: {}x{} - {}x{})".format(
        title, pid, left, top, right, bottom))

    # Iniciar gravacao
    recording = True
    actions = []
    start_time = time.time()
    print("GRAVACAO INICIADA. Cliques e teclas serao gravados apenas dentro da janela.")
    print("Pressione ESC para interromper e salvar.")
    print("-"*60)

    def on_click(x, y, button, pressed):
        nonlocal actions, start_time
        if not recording or not pressed or hwnd is None:
            return
        print("Clique detectado em (x={}, y={})".format(x, y))
        if is_point_inside_window(x, y, hwnd):
            left, top, _, _ = get_window_rect(hwnd)
            rel_x = x - left
            rel_y = y - top
            action = {
                'type': 'click',
                'button': button.name,
                'x': rel_x,
                'y': rel_y,
                'timestamp': time.time() - start_time
            }
            actions.append(action)
            print("  -> DENTRO da janela. Registrado em ({}, {})".format(rel_x, rel_y))
        else:
            print("  -> FORA da janela. Ignorado.")

    def on_press(key):
        nonlocal recording
        if key == STOP_KEY:
            print("Interrompendo...")
            recording = False
            return False
        if recording:
            # Obter a janela em primeiro plano
            fg_hwnd = win32gui.GetForegroundWindow()
            if fg_hwnd:
                # Verificar se a janela em foco pertence ao mesmo processo da janela alvo
                fg_pid = get_process_id_from_window(fg_hwnd)
                if fg_pid == pid:
                    try:
                        key_name = key.char
                    except AttributeError:
                        key_name = str(key).replace('Key.', '')
                    action = {
                        'type': 'key',
                        'key': key_name,
                        'timestamp': time.time() - start_time
                    }
                    actions.append(action)
                    print("Tecla '{}' registrada".format(key_name))
                else:
                    print("Tecla ignorada (janela em foco nao pertence ao processo alvo)")
            else:
                print("Tecla ignorada (nenhuma janela em foco)")

    with mouse.Listener(on_click=on_click) as mouse_listener, \
         keyboard.Listener(on_press=on_press) as keyboard_listener:
        while recording:
            time.sleep(0.5)
        mouse_listener.stop()
        keyboard_listener.stop()

    print("GRAVACAO FINALIZADA.")
    if actions:
        desktop = get_desktop_path()
        filename = os.path.join(desktop, "macro_{}.json".format(int(time.time())))
        with open(filename, 'w') as f:
            json.dump(actions, f, indent=2)
        print("Macro salva em {} com {} acoes.".format(filename, len(actions)))
    else:
        print("Nenhuma acao gravada.")

if __name__ == "__main__":
    main()
