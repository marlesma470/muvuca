from PySide6.QtGui import QFont
from PySide6.QtWidgets import (
    QDialog, QVBoxLayout, QHBoxLayout, QGridLayout, QLabel,
    QLineEdit, QPushButton, QComboBox, QCheckBox, QSpinBox,
    QDateTimeEdit, QGroupBox, QMessageBox, QDialogButtonBox,
    QProgressDialog, QApplication
)

from ..models import Agendamento, Periodicidade
from ..database import get_session, salvar_agendamento, carregar_agendamento_por_nome
from ..theme_preference import ThemePreference
from ..logger import logger
from ..executor_simples import ExecutorWorker


class EditarAutomacaoDialog(QDialog):

    def __init__(self, agendamento: Agendamento, grupo: str, parent=None):
        super().__init__(parent)
        self.agendamento_original = agendamento
        self.grupo = grupo
        self.script_path_original = agendamento.script_path
        self.nome_original = agendamento.nome_script
        self.teste_worker = None
        self.progress_dialog = None

        self._setup_ui()
        self._carregar_valores()
        self._aplicar_tema()
        self.setWindowFlags(self.windowFlags() | Qt.WindowMaximizeButtonHint)
        self.resize(550, 560)
        self.setMinimumSize(450, 500)

    def _setup_ui(self):
        self.setWindowTitle(f"Editar Automação - {self.agendamento_original.nome_script}")

        layout = QVBoxLayout(self)
        layout.setSpacing(15)
        layout.setContentsMargins(20, 20, 20, 20)

        # Grupo: Nome
        gb_nome = QGroupBox("Nome da automação")
        gb_nome.setStyleSheet("QGroupBox { margin-top: 15px; }")
        nome_layout = QHBoxLayout(gb_nome)
        self.txt_nome = QLineEdit()
        self.txt_nome.setPlaceholderText("Digite o nome da automação")
        nome_layout.addWidget(self.txt_nome)
        layout.addWidget(gb_nome)

        # Grupo: Agendamento
        gb_agendamento = QGroupBox("Agendamento")
        gb_agendamento.setStyleSheet("QGroupBox { margin-top: 15px; }")
        grid = QGridLayout(gb_agendamento)
        grid.setVerticalSpacing(10)
        grid.setHorizontalSpacing(15)
        grid.setContentsMargins(15, 20, 15, 15)

        grid.addWidget(QLabel("Horário (HH:MM:SS):"), 0, 0)
        self.dt_horario = QDateTimeEdit()
        self.dt_horario.setDisplayFormat("HH:mm:ss")
        self.dt_horario.setTime(QTime(8, 0, 0))
        self.dt_horario.setCalendarPopup(True)
        grid.addWidget(self.dt_horario, 0, 1)

        grid.addWidget(QLabel("Data início:"), 1, 0)
        self.dt_data_inicio = QDateTimeEdit()
        self.dt_data_inicio.setDisplayFormat("dd/MM/yyyy")
        self.dt_data_inicio.setCalendarPopup(True)
        data_inicio = datetime.now().replace(hour=0, minute=0, second=0, microsecond=0) + timedelta(days=1)
        qdate = QDate(data_inicio.year, data_inicio.month, data_inicio.day)
        qtime = QTime(0, 0, 0)
        self.dt_data_inicio.setDateTime(QDateTime(qdate, qtime))
        grid.addWidget(self.dt_data_inicio, 1, 1)

        grid.addWidget(QLabel("Periodicidade:"), 2, 0)
        self.cmb_periodicidade = QComboBox()
        self.cmb_periodicidade.addItems([
            "Diário (dias corridos)", "Diário (dias úteis)", "Semanal",
            "Mensal", "Quinzenal", "Anual"
        ])
        self.cmb_periodicidade.currentIndexChanged.connect(self._periodicidade_changed)
        grid.addWidget(self.cmb_periodicidade, 2, 1)

        grid.addWidget(QLabel("Dia semana:"), 3, 0)
        self.cmb_dia_semana = QComboBox()
        self.cmb_dia_semana.addItems(["Domingo", "Segunda", "Terça", "Quarta", "Quinta", "Sexta", "Sábado"])
        self.cmb_dia_semana.setVisible(False)
        grid.addWidget(self.cmb_dia_semana, 3, 1)

        grid.addWidget(QLabel("Dia mês:"), 4, 0)
        self.spin_dia_mes = QSpinBox()
        self.spin_dia_mes.setRange(1, 31)
        self.spin_dia_mes.setValue(1)
        self.spin_dia_mes.setVisible(False)
        grid.addWidget(self.spin_dia_mes, 4, 1)

        grid.addWidget(QLabel("Regra dia útil:"), 5, 0)
        self.cmb_regra_dia_util = QComboBox()
        self.cmb_regra_dia_util.addItems(["Dia corrido", "Dia útil anterior", "Dia útil posterior"])
        self.cmb_regra_dia_util.setCurrentIndex(0)
        self.cmb_regra_dia_util.setVisible(False)
        grid.addWidget(self.cmb_regra_dia_util, 5, 1)

        grid.addWidget(QLabel("Dia ano:"), 6, 0)
        self.spin_dia_ano = QSpinBox()
        self.spin_dia_ano.setRange(1, 365)
        self.spin_dia_ano.setValue(1)
        self.spin_dia_ano.setVisible(False)
        grid.addWidget(self.spin_dia_ano, 6, 1)

        self.chk_ativo = QCheckBox("Agendamento ativo")
        self.chk_ativo.setChecked(True)
        grid.addWidget(self.chk_ativo, 7, 0, 1, 2)

        layout.addWidget(gb_agendamento)

        # Botão Resetar Retorno
        gb_reset = QGroupBox("Retorno da automação")
        gb_reset.setStyleSheet("QGroupBox { margin-top: 15px; }")
        reset_layout = QHBoxLayout(gb_reset)
        lbl_info = QLabel("O retorno fica visível para todos os usuários.\nClique no botão para limpar manualmente.")
        lbl_info.setWordWrap(True)
        reset_layout.addWidget(lbl_info)
        self.btn_reset_retorno = QPushButton("Resetar Retorno")
        self.btn_reset_retorno.setObjectName("btn_reset_retorno")
        self.btn_reset_retorno.setFixedSize(140, 32)
        self.btn_reset_retorno.clicked.connect(self._resetar_retorno)
        reset_layout.addWidget(self.btn_reset_retorno)
        layout.addWidget(gb_reset)

        # Grupo: Teste
        gb_teste = QGroupBox("Teste da automação")
        gb_teste.setStyleSheet("QGroupBox { margin-top: 15px; }")
        teste_layout = QHBoxLayout(gb_teste)
        lbl_teste_info = QLabel("Execute a automação em modo visível para depuração.")
        lbl_teste_info.setWordWrap(True)
        teste_layout.addWidget(lbl_teste_info)
        self.btn_testar = QPushButton("Testar (visível)")
        self.btn_testar.setObjectName("btn_testar")
        self.btn_testar.setFixedSize(140, 32)
        self.btn_testar.clicked.connect(self._testar_automacao)
        teste_layout.addWidget(self.btn_testar)
        layout.addWidget(gb_teste)

        # Botões OK / Cancelar
        btn_box = QDialogButtonBox()
        btn_box.setOrientation(Qt.Horizontal)
        btn_box.setStandardButtons(QDialogButtonBox.Ok | QDialogButtonBox.Cancel)
        btn_box.accepted.connect(self._salvar)
        btn_box.rejected.connect(self.reject)
        layout.addWidget(btn_box)

    def _carregar_valores(self):
        ag = self.agendamento_original
        self.txt_nome.setText(ag.nome_script)
        self.dt_horario.setTime(QTime(ag.horario_execucao.hour, ag.horario_execucao.minute, ag.horario_execucao.second))
        qdate = QDate(ag.data_inicio.year, ag.data_inicio.month, ag.data_inicio.day)
        qtime = QTime(0, 0, 0)
        self.dt_data_inicio.setDateTime(QDateTime(qdate, qtime))

        periodicidade_map = {
            Periodicidade.DIARIA: "Diário (dias corridos)",
            Periodicidade.DIARIA_UTIL: "Diário (dias úteis)",
            Periodicidade.SEMANAL: "Semanal",
            Periodicidade.MENSAL: "Mensal",
            Periodicidade.QUINZENAL: "Quinzenal",
            Periodicidade.ANUAL: "Anual"
        }
        texto_period = periodicidade_map.get(ag.periodicidade, "Diário (dias corridos)")
        idx = self.cmb_periodicidade.findText(texto_period)
        if idx >= 0:
            self.cmb_periodicidade.setCurrentIndex(idx)

        if ag.periodicidade == Periodicidade.SEMANAL:
            self.cmb_dia_semana.setCurrentIndex(ag.dia_semana)

        if ag.periodicidade == Periodicidade.MENSAL:
            self.spin_dia_mes.setValue(ag.dia_mes)
            if hasattr(ag, 'regra_dia_util') and ag.regra_dia_util:
                idx_regra = self.cmb_regra_dia_util.findText(ag.regra_dia_util)
                if idx_regra >= 0:
                    self.cmb_regra_dia_util.setCurrentIndex(idx_regra)

        if ag.periodicidade == Periodicidade.ANUAL:
            self.spin_dia_ano.setValue(ag.dia_ano)

        self.chk_ativo.setChecked(ag.ativo)
        self._periodicidade_changed(self.cmb_periodicidade.currentIndex())

    def _periodicidade_changed(self, idx: int):
        texto = self.cmb_periodicidade.currentText()
        is_semanal = texto == "Semanal"
        is_mensal = texto == "Mensal"
        is_anual = texto == "Anual"

        self.cmb_dia_semana.setVisible(is_semanal)
        self.spin_dia_mes.setVisible(is_mensal)
        self.cmb_regra_dia_util.setVisible(is_mensal)
        self.spin_dia_ano.setVisible(is_anual)

    def _resetar_retorno(self):
        """Reseta o campo de retorno e o status para 'Aguardando'."""
        reply = QMessageBox.question(
            self,
            "Resetar retorno",
            "Tem certeza que deseja limpar o retorno desta automação?\n\nO status será alterado para 'Aguardando' e o retorno será removido.",
            QMessageBox.Yes | QMessageBox.No,
            QMessageBox.No
        )
        if reply == QMessageBox.Yes:
            ag = self.agendamento_original
            ag.status = "Aguardando"
            ag.resultado_execucao = ""
            ag.expirado = False
            # Salva imediatamente no banco
            with get_session() as session:
                salvar_agendamento(session, ag)
            logger.info(f"Retorno resetado para '{ag.nome_script}'")
            QMessageBox.information(self, "Reset concluído", "O retorno foi limpo e o status alterado para 'Aguardando'.")

    def _testar_automacao(self):
        if not os.path.exists(self.script_path_original):
            QMessageBox.warning(self, "Erro", f"Script não encontrado:\n{self.script_path_original}")
            return

        ag_temp = self.agendamento_original
        ag_temp.nome_script = self.txt_nome.text().strip() or ag_temp.nome_script

        self.btn_testar.setEnabled(False)
        self.progress_dialog = QProgressDialog("Executando teste...", "Cancelar", 0, 0, self)
        self.progress_dialog.setWindowModality(Qt.WindowModal)
        self.progress_dialog.setCancelButton(None)
        self.progress_dialog.show()

        self.teste_worker = ExecutorWorker(ag_temp, self.grupo, headless=False)
        self.teste_worker.finished.connect(self._on_teste_finished)
        self.teste_worker.start()

    def _on_teste_finished(self, nome: str, sucesso: bool, mensagem: str, logs: list):
        if self.progress_dialog:
            self.progress_dialog.close()
            self.progress_dialog = None
        self.btn_testar.setEnabled(True)

        if sucesso:
            QMessageBox.information(
                self,
                "Teste concluído",
                f"Automação executada com sucesso!\n\n{mensagem[:500]}"
            )
        else:
            QMessageBox.warning(
                self,
                "Teste falhou",
                f"Falha na execução do teste.\n\n{mensagem[:500]}"
            )

        self.teste_worker = None

    def _salvar(self):
        nome = self.txt_nome.text().strip()
        if not nome:
            QMessageBox.warning(self, "Erro", "O nome da automação não pode estar vazio.")
            return

        with get_session() as session:
            existente = carregar_agendamento_por_nome(session, nome, self.grupo)
            if existente and existente.nome_script != self.nome_original:
                QMessageBox.warning(
                    self,
                    "Erro",
                    f"Já existe uma automação com o nome '{nome}' no grupo '{self.grupo}'."
                )
                return

        ag = self.agendamento_original
        ag.nome_script = nome
        ag.horario_execucao = self.dt_horario.time().toPython()
        ag.data_inicio = self.dt_data_inicio.dateTime().toPython()

        periodicidade_texto = self.cmb_periodicidade.currentText()
        if periodicidade_texto == "Diário (dias corridos)":
            ag.periodicidade = Periodicidade.DIARIA
        elif periodicidade_texto == "Diário (dias úteis)":
            ag.periodicidade = Periodicidade.DIARIA_UTIL
        elif periodicidade_texto == "Semanal":
            ag.periodicidade = Periodicidade.SEMANAL
        elif periodicidade_texto == "Mensal":
            ag.periodicidade = Periodicidade.MENSAL
        elif periodicidade_texto == "Quinzenal":
            ag.periodicidade = Periodicidade.QUINZENAL
        elif periodicidade_texto == "Anual":
            ag.periodicidade = Periodicidade.ANUAL
        else:
            ag.periodicidade = Periodicidade.DIARIA

        ag.dia_semana = self.cmb_dia_semana.currentIndex()
        ag.dia_mes = self.spin_dia_mes.value()
        ag.dia_ano = self.spin_dia_ano.value()
        ag.ativo = self.chk_ativo.isChecked()
        ag.regra_dia_util = self.cmb_regra_dia_util.currentText() if ag.periodicidade == Periodicidade.MENSAL else ""

        # Recalcula próxima execução, mas NÃO mexe no retorno nem no status
        ag.atualizar_proxima_execucao()
        if ag.expirado or ag.status == "Expirado":
            ag.reativar()
            # Não limpa retorno, mantém o que estava

        if nome != self.nome_original and self.script_path_original:
            dirname = os.path.dirname(self.script_path_original)
            ext = os.path.splitext(self.script_path_original)[1]
            novo_caminho = os.path.join(dirname, f"{nome}{ext}")
            try:
                shutil.move(self.script_path_original, novo_caminho)
                ag.script_path = novo_caminho
                logger.info(f"Script renomeado: {self.script_path_original} -> {novo_caminho}")
            except Exception as e:
                QMessageBox.critical(self, "Erro", f"Não foi possível renomear o arquivo:\n{str(e)}")
                return

        try:
            with get_session() as session:
                salvar_agendamento(session, ag)
            logger.info(f"Agendamento '{nome}' atualizado com sucesso.")
            self.accept()
        except Exception as e:
            QMessageBox.critical(self, "Erro", f"Falha ao salvar no banco de dados:\n{str(e)}")

