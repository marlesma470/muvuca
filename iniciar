        "&state=jTb856Ff74qjqGWPeJL797yHLK-f8sBf9hKkIzp0QVA%3D"
        "&redirect_uri=https://www.rtm.selic.gov.br/portal-selic/login/oauth2/code/sso"
        "&nonce=3cwEHiw5JQUISKiBjTPYRHJ4ow5eUC7YjLmQsOF4wAM"
    )
    page.goto(url_login, wait_until="networkidle", timeout=60000)

    # Preenche iSelic
