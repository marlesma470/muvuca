class ProgressBarDelegate(QStyledItemDelegate):
    def __init__(self, parent=None):
        super().__init__(parent)

    def paint(self, painter, option, index):
        if not index.isValid():
            return
        table = index.model().parent()
        if not hasattr(table, 'agendamentos'):
            super().paint(painter, option, index)
            return
        row = index.row()
        if row < 0 or row >= len(table.agendamentos):
            super().paint(painter, option, index)
            return
        ag = table.agendamentos[row]
        if not ag:
            super().paint(painter, option, index)
            return

        remaining = ag.time_until_next()
        total_seconds = remaining.total_seconds()
        if total_seconds < 0:
            total_seconds = 0

        max_seconds = 86400
        frac = (max_seconds - total_seconds) / max_seconds
        percent = max(0, min(1, frac * frac * frac * frac))

        if total_seconds > 3600:
            bar_color = QColor(0, 180, 0)
        elif total_seconds > 600:
            bar_color = QColor(218, 165, 32)
        else:
            bar_color = QColor(255, 0, 0)

        painter.save()
        painter.fillRect(option.rect, QColor(240, 240, 240, 50))
        painter.setPen(Qt.NoPen)

        bar_rect = QRect(option.rect)
        bar_rect.setX(bar_rect.x() + 2)
        bar_rect.setY(bar_rect.y() + 2)
        bar_rect.setWidth(max(1, int(bar_rect.width() * percent)))
        bar_rect.setHeight(bar_rect.height() - 4)
        painter.fillRect(bar_rect, bar_color)

        if total_seconds > 0:
            days = int(total_seconds // 86400)
            hours = int((total_seconds % 86400) // 3600)
            minutes = int((total_seconds % 3600) // 60)
            seconds = int(total_seconds % 60)
            if days > 0:
                texto = f"{days}d {hours}h {minutes}m {seconds}s"
            elif hours > 0:
                texto = f"{hours}h {minutes}m {seconds}s"
            elif minutes > 0:
                texto = f"{minutes}m {seconds}s"
            else:
                texto = f"{seconds}s"
            texto += " restante"
        else:
            texto = "0s"

        if ThemePreference.is_dark():
            painter.setPen(QColor(255, 255, 255))
        else:
            painter.setPen(QColor(0, 0, 0))
        painter.drawText(option.rect, Qt.AlignCenter, texto)
        painter.restore()


