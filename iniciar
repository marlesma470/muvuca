import json
import time
import subprocess
import os
import win32gui
import win32process
import psutil
from pynput import mouse, keyboard

# ================= FUNÇÕES AUXILIARES =================
def obter_configuracoes():
    """Solicita ao usuário as configurações do sistema a ser automatizado."""
    print("\n" + "="*60)
    print("🎬 GRAVADOR DE MACROS UNIVERSAL")
    print("="*60)
    
    # 1. Caminho do executável
    while True:
        exe_path = input("📁 Caminho completo do executável (ex: C:\\Programas\\MeuSistema.exe): ").strip()
        if exe_path and os.path.exists(exe_path):
            break
        print("❌ Arquivo não encontrado. Tente novamente.")
    
    # 2. Nome do processo (opcional)
    default_process = os.path.basename(exe_path)
    process_name = input(f"🔄 Nome do processo (padrão: {default_process}): ").strip()
    if not process_name:
        process_name = default_process
    
    # 3. Título da janela (opcional)
    window_title = input("🪟 Título da janela (opcional, deixe em branco para ignorar): ").strip()
    
    print("\n✅ Configurações salvas:")
    print(f"   Executável: {exe_path}")
    print(f"   Processo: {process_name}")
    if window_title:
        print(f"   Título (fallback): {window_title}")
    else:
        print("   Título (fallback): não definido")
    print("\n" + "="*60)
    
    return exe_path, process_name, window_title

# ================= FUNÇÕES DE JANELA =================
def find_window_by_process(process_name):
    """Encontra a janela pelo nome do processo."""
    for proc in psutil.process_iter(['pid', 'name']):
        if proc.info['name'].lower() == process_name.lower():
            pid = proc.info['pid']
            def callback(hwnd, hwnds):
                if win32gui.IsWindowVisible(hwnd):
                    _, found_pid = win32process.GetWindowThreadProcessId(hwnd)
                    if found_pid == pid:
                        hwnds.append(hwnd)
                return True
            hwnds = []
            win32gui.EnumWindows(callback, hwnds)
            if hwnds:
                return hwnds[0]
    return None

def find_window_by_title(title):
    """Encontra a janela pelo título (parcial)."""
    def callback(hwnd, hwnds):
        if win32gui.IsWindowVisible(hwnd):
            window_text = win32gui.GetWindowText(hwnd)
            if title.lower() in window_text.lower():
                hwnds.append(hwnd)
        return True
    hwnds = []
    win32gui.EnumWindows(callback, hwnds)
    return hwnds[0] if hwnds else None

def get_window_rect(hwnd):
    return win32gui.GetWindowRect(hwnd)

def is_point_inside_window(x, y, hwnd):
    if not hwnd:
        return False
    left, top, right, bottom = get_window_rect(hwnd)
    return left <= x <= right and top <= y <= bottom

def is_process_running(process_name):
    for proc in psutil.process_iter(['name']):
        if proc.info['name'].lower() == process_name.lower():
            return True
    return False

# ================= GRAVADOR =================
def main():
    # Obtém configurações do usuário
    exe_path, process_name, window_title = obter_configuracoes()
    
    # Variáveis globais
    global recording, actions, start_time, hwnd, program_running
    recording = False
    actions = []
    start_time = None
    hwnd = None
    program_running = True
    STOP_KEY = keyboard.Key.esc
    
    # Abre o aplicativo
    try:
        print(f"🚀 Abrindo {exe_path}...")
        subprocess.Popen([exe_path])
        inicio = time.time()
        while True:
            # Tenta encontrar pelo processo
            hwnd = find_window_by_process(process_name)
            if hwnd:
                break
            # Se tiver título definido, tenta por ele
            if window_title:
                hwnd = find_window_by_title(window_title)
                if hwnd:
                    break
            if time.time() - inicio > 30:
                print("❌ Tempo limite: aplicativo não abriu.")
                return
            time.sleep(0.5)
        print(f"✅ Janela encontrada.")
    except Exception as e:
        print(f"❌ Erro: {e}")
        return
    
    # Inicia gravação
    recording = True
    start_time = time.time()
    print("▶️ GRAVAÇÃO INICIADA automaticamente!")
    print(f"Pressione {STOP_KEY} para interromper e salvar.")
    
    # ===== CALLBACKS =====
    def on_click(x, y, button, pressed):
        global recording, actions, start_time, hwnd
        if not recording or not pressed or hwnd is None:
            return
        if is_point_inside_window(x, y, hwnd):
            left, top, _, _ = get_window_rect(hwnd)
            rel_x = x - left
            rel_y = y - top
            action = {
                'type': 'click',
                'button': button.name,
                'x': rel_x,
                'y': rel_y,
                'timestamp': time.time() - start_time
            }
            actions.append(action)
            print(f"✅ Clique {button.name} em ({rel_x}, {rel_y})")
        else:
            print(f"⏭️ Clique fora da janela ignorado.")
    
    def on_press(key):
        global recording, program_running
        if key == STOP_KEY:
            print("👋 Interrompendo...")
            program_running = False
            return False
        if recording:
            fg_hwnd = win32gui.GetForegroundWindow()
            if hwnd is not None and fg_hwnd == hwnd:
                try:
                    key_name = key.char
                except AttributeError:
                    key_name = str(key).replace('Key.', '')
                action = {
                    'type': 'key',
                    'key': key_name,
                    'timestamp': time.time() - start_time
                }
                actions.append(action)
                print(f"⌨️ Tecla '{key_name}' registrada")
            else:
                print(f"⏭️ Tecla ignorada (janela não em foco)")
    
    # Inicia listeners
    with mouse.Listener(on_click=on_click) as mouse_listener, \
         keyboard.Listener(on_press=on_press) as keyboard_listener:
        while program_running and recording:
            if not is_process_running(process_name):
                print("⚠️ Aplicativo fechado. Encerrando...")
                recording = False
                break
            time.sleep(0.5)
        mouse_listener.stop()
        keyboard_listener.stop()
    
    # Salva macro
    print("⏹️ GRAVAÇÃO FINALIZADA.")
    if actions:
        filename = f"macro_{int(time.time())}.json"
        with open(filename, 'w') as f:
            json.dump(actions, f, indent=2)
        print(f"💾 Macro salva em {filename} com {len(actions)} ações.")
    else:
        print("Nenhuma ação gravada.")

if __name__ == "__main__":
    main()
