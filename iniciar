import json
import time
import subprocess
import win32gui
import win32process
import psutil
from pynput import mouse, keyboard

# ================= CONFIGURAÇÕES =================
EXE_PATH = r"C:\Program Files\XCloud\XCloud.exe"
PROCESS_NAME = "XCloud.exe"  # nome do processo (pode ser sem .exe)
STOP_KEY = keyboard.Key.esc  # tecla para interromper a gravação manualmente

# ================= ESTADO GLOBAL =================
recording = False
actions = []
start_time = None
hwnd = None
program_running = True

# ================= FUNÇÕES DE JANELA =================
def find_window_by_process(process_name):
    """Retorna o handle da janela principal do processo (primeira janela visível)."""
    for proc in psutil.process_iter(['pid', 'name']):
        if proc.info['name'].lower() == process_name.lower():
            pid = proc.info['pid']
            # Lista todas as janelas e verifica qual pertence a esse PID
            def callback(hwnd, hwnds):
                if win32gui.IsWindowVisible(hwnd):
                    _, found_pid = win32process.GetWindowThreadProcessId(hwnd)
                    if found_pid == pid:
                        hwnds.append(hwnd)
                return True
            hwnds = []
            win32gui.EnumWindows(callback, hwnds)
            if hwnds:
                return hwnds[0]  # primeira janela encontrada
    return None

def get_window_rect(hwnd):
    return win32gui.GetWindowRect(hwnd)

def is_point_inside_window(x, y, hwnd):
    if not hwnd:
        return False
    left, top, right, bottom = get_window_rect(hwnd)
    return left <= x <= right and top <= y <= bottom

def is_process_running(process_name):
    """Verifica se o processo ainda está em execução."""
    for proc in psutil.process_iter(['name']):
        if proc.info['name'].lower() == process_name.lower():
            return True
    return False

# ================= CALLBACKS =================
def on_click(x, y, button, pressed):
    global recording, actions, start_time, hwnd
    if not recording:
        return
    if not pressed:
        return
    if hwnd is None:
        return
    if is_point_inside_window(x, y, hwnd):
        left, top, _, _ = get_window_rect(hwnd)
        rel_x = x - left
        rel_y = y - top
        action = {
            'type': 'click',
            'button': button.name,
            'x': rel_x,
            'y': rel_y,
            'timestamp': time.time() - start_time
        }
        actions.append(action)
        print(f"✅ Clique {button.name} em ({rel_x}, {rel_y})")
    else:
        print(f"⏭️ Clique fora da janela ignorado.")

def on_press(key):
    global recording, program_running
    # Se pressionar ESC, interrompe a gravação e finaliza
    if key == STOP_KEY:
        print("👋 Interrompendo pelo usuário...")
        program_running = False
        return False  # para o listener
    # Grava teclas apenas se estiver gravando e a janela estiver em foco
    if recording:
        # verifica se a janela está em primeiro plano
        fg_hwnd = win32gui.GetForegroundWindow()
        if hwnd is not None and fg_hwnd == hwnd:
            try:
                key_name = key.char
            except AttributeError:
                key_name = str(key).replace('Key.', '')
            action = {
                'type': 'key',
                'key': key_name,
                'timestamp': time.time() - start_time
            }
            actions.append(action)
            print(f"⌨️ Tecla '{key_name}' registrada")
        else:
            print(f"⏭️ Tecla ignorada (janela não está em foco)")

# ================= SALVAR MACRO =================
def save_macro():
    if actions:
        filename = f"macro_{int(time.time())}.json"
        with open(filename, 'w') as f:
            json.dump(actions, f, indent=2)
        print(f"💾 Macro salva em {filename} com {len(actions)} ações.")
    else:
        print("Nenhuma ação gravada.")

# ================= ABRIR APLICATIVO =================
def open_app():
    global hwnd
    try:
        print(f"🚀 Abrindo {EXE_PATH}...")
        subprocess.Popen([EXE_PATH])
        # Aguarda o processo aparecer e a janela ser detectada
        inicio = time.time()
        while True:
            hwnd = find_window_by_process(PROCESS_NAME)
            if hwnd:
                break
            if time.time() - inicio > 30:  # timeout de 30s
                print("❌ Tempo limite: aplicativo não abriu.")
                return False
            time.sleep(0.5)
        print(f"✅ Janela do {PROCESS_NAME} encontrada.")
        return True
    except Exception as e:
        print(f"❌ Erro ao abrir: {e}")
        return False

# ================= MAIN =================
def main():
    global recording, start_time, hwnd, program_running

    print("="*60)
    print("🎬 GRAVADOR AUTOMÁTICO - XCloud")
    print("="*60)
    print("A gravação começará automaticamente quando o aplicativo abrir.")
    print(f"Pressione {STOP_KEY} para interromper e salvar.")
    print("="*60)

    # Abre o aplicativo
    if not open_app():
        return

    # Inicia a gravação automaticamente
    recording = True
    start_time = time.time()
    print("▶️ GRAVAÇÃO INICIADA automaticamente!")

    # Inicia os listeners
    with mouse.Listener(on_click=on_click) as mouse_listener, \
         keyboard.Listener(on_press=on_press) as keyboard_listener:
        # Fica em loop enquanto o processo estiver rodando e a gravação estiver ativa
        while program_running and recording:
            # Verifica se o processo ainda está em execução
            if not is_process_running(PROCESS_NAME):
                print("⚠️ O aplicativo foi fechado. Encerrando gravação...")
                recording = False
                break
            time.sleep(0.5)  # verifica a cada 500ms
        # Para os listeners
        mouse_listener.stop()
        keyboard_listener.stop()

    # Salva a macro ao sair
    print("⏹️ GRAVAÇÃO FINALIZADA.")
    save_macro()
    print("Programa encerrado.")

if __name__ == "__main__":
    main()
