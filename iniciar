    def _gerar_atalho_para_grupo(self, grupo: str):
        try:
            base_dir = os.getcwd()
            bat_path = os.path.join(base_dir, f"iniciar_{grupo}.bat")
            with open(bat_path, 'w', encoding='utf-8') as f:
                f.write(f"""@echo off
title Sistema de Automação (Leve) - Grupo {grupo}
set PYTHON_DIR=%~dp0python-portable
set PYTHON_EXE=%PYTHON_DIR%\\pythonw.exe
start "" "%PYTHON_EXE%" main.py --grupo {grupo}
exit
""")
            vbs_path = os.path.join(base_dir, f"iniciar_{grupo}.vbs")
            with open(vbs_path, 'w', encoding='utf-8') as f:
                f.write(f"""' iniciar_{grupo}.vbs
Set objShell = CreateObject("WScript.Shell")
strPath = CreateObject("Scripting.FileSystemObject").GetParentFolderName(WScript.ScriptFullName)
objShell.Run "cmd /c " & strPath & "\\iniciar_{grupo}.bat", 0, False
""")
            logger.info(f"Atalhos gerados para grupo '{grupo}'")
        except Exception as e:
            logger.warning(f"Erro ao gerar atalhos para {grupo}: {e}")

    def _sincronizar_pasta(self, grupo: str):
        pasta_grupo = os.path.join(self.pasta_atividades, grupo)
        if not os.path.exists(pasta_grupo):
            os.makedirs(pasta_grupo, exist_ok=True)
            self._gerar_atalho_para_grupo(grupo)
            return

        arquivos_py = []
        for arquivo in os.listdir(pasta_grupo):
            if arquivo.endswith('.py') and os.path.isfile(os.path.join(pasta_grupo, arquivo)):
                arquivos_py.append(arquivo)

        if not arquivos_py:
            return

        with get_session() as session:
            existentes = carregar_agendamentos(session, grupo)
            nomes_existentes = {ag.nome_script for ag in existentes}

            for nome_arquivo in arquivos_py:
                nome_sem_ext = os.path.splitext(nome_arquivo)[0]
                caminho_completo = os.path.join(pasta_grupo, nome_arquivo)

                if nome_sem_ext in nomes_existentes:
                    for ag in existentes:
                        if ag.nome_script == nome_sem_ext and ag.script_path != caminho_completo:
                            ag.script_path = caminho_completo
                            salvar_agendamento(session, ag)
                            logger.info(f"Caminho atualizado para {nome_sem_ext}")
                    continue

                ag = Agendamento()
                ag.nome_script = nome_sem_ext
                ag.tipo = "Python"
                ag.script_path = caminho_completo
                ag.grupo_origem = grupo
                ag.periodicidade = Periodicidade.DIARIA
                ag.horario_execucao = datetime.now().time().replace(hour=8, minute=0, second=0)
                ag.data_inicio = datetime.now() + timedelta(days=1)
                ag.proxima_execucao = ag.calcular_proxima_execucao_apartir_de(datetime.now())
                ag.ativo = True
                ag.status = "Aguardando"

                salvar_agendamento(session, ag)
                logger.info(f"Novo agendamento criado para {nome_sem_ext} (grupo {grupo})")

            for ag in existentes:
                if ag.nome_script not in [os.path.splitext(f)[0] for f in arquivos_py]:
                    excluir_agendamento(session, ag.nome_script, grupo)
                    logger.info(f"Agendamento removido: {ag.nome_script} (arquivo não encontrado)")

    def _sincronizar_com_pasta(self):
        if self.eh_todos:
            for item in os.listdir(self.pasta_atividades):
                caminho = os.path.join(self.pasta_atividades, item)
                if os.path.isdir(caminho):
                    self._sincronizar_pasta(item)
        else:
            self._sincronizar_pasta(self.grupo_selecionado)

