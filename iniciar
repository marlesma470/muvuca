@echo off
title Sistema de Automação (Leve)

:: Define a letra da unidade a ser usada (verifica se Z: está livre)
set "DRIVE=Z:"
set "UNC_PATH=%~dp0"
set "UNC_PATH=%UNC_PATH:~0,-1%"

:: Verifica se Z: já está em uso
net use %DRIVE% >nul 2>&1
if not errorlevel 1 (
    echo A unidade %DRIVE% ja esta em uso. Usando Y:...
    set "DRIVE=Y:"
)

:: Mapeia a pasta de rede
net use %DRIVE% "%UNC_PATH%" /persistent:no
if errorlevel 1 (
    echo ERRO: Nao foi possivel mapear %UNC_PATH% para %DRIVE%
    pause
    exit /b 1
)

:: Muda para a unidade mapeada
%DRIVE%
cd "%UNC_PATH%"

:: Executa o sistema
set "PYTHON_DIR=%CD%\python-portable"
set "PYTHON_EXE=%PYTHON_DIR%\python.exe"

if not exist "%PYTHON_EXE%" (
    echo ERRO: Python nao encontrado em %PYTHON_EXE%
    net use %DRIVE% /delete /y
    pause
    exit /b 1
)

echo Executando sistema em %CD%...
"%PYTHON_EXE%" main.py

:: Desmapeia a unidade
net use %DRIVE% /delete /y
pause
