# -----------------------------------------------------------------------------
# FUNÇÃO PARA BAIXAR ARQUIVO (PLAYWRIGHT)
# -----------------------------------------------------------------------------

def baixar_arquivo(page, timeout=60000):
    """
    Clica no botão de download (identificado pelo título 'Download') e
    salva o arquivo na pasta DOWNLOAD_DIR com o nome original.
    """
    with page.expect_download(timeout=timeout) as download_info:
        # Clica no botão de download (pode ser o primeiro encontrado)
        page.locator('button[title="Download"]').first.click()

    download = download_info.value
    nome_original = download.suggested_filename
    destino = os.path.join(DOWNLOAD_DIR, nome_original)

    # Remove se já existir (opcional)
    if os.path.exists(destino):
        os.remove(destino)

    download.save_as(destino)
    print(f"Arquivo baixado: {destino}")
    return destino

