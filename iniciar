import json
import time
import os
import win32gui
import win32process
import psutil
from pynput import mouse, keyboard

# ================= CONFIGURACOES =================
STOP_KEY = keyboard.Key.esc

# ================= FUNCOES =================

def listar_janelas_visiveis():
    """Retorna uma lista de dicionários com handle e título das janelas visíveis com título não vazio."""
    janelas = []
    def callback(hwnd, extra):
        if win32gui.IsWindowVisible(hwnd):
            titulo = win32gui.GetWindowText(hwnd)
            if titulo:  # ignora janelas sem título
                janelas.append({'hwnd': hwnd, 'titulo': titulo})
        return True
    win32gui.EnumWindows(callback, None)
    return janelas

def selecionar_janela():
    print("\n" + "="*60)
    print("GRAVADOR DE MACROS UNIVERSAL")
    print("="*60)
    print("Listando janelas abertas...\n")
    janelas = listar_janelas_visiveis()
    if not janelas:
        print("Nenhuma janela com titulo encontrada.")
        return None
    
    # Exibe numeradas
    for i, janela in enumerate(janelas, 1):
        # Tenta obter o nome do processo para ajudar na identificação
        try:
            _, pid = win32process.GetWindowThreadProcessId(janela['hwnd'])
            processo = psutil.Process(pid)
            nome_processo = processo.name()
        except:
            nome_processo = "desconhecido"
        print("{}. {} (processo: {})".format(i, janela['titulo'], nome_processo))
    
    print("\nDigite o numero da janela que deseja gravar (ou 0 para sair):")
    while True:
        try:
            opcao = int(input("> "))
            if opcao == 0:
                return None
            if 1 <= opcao <= len(janelas):
                return janelas[opcao-1]
            else:
                print("Opcao invalida. Tente novamente.")
        except ValueError:
            print("Digite um numero valido.")

def get_desktop_path():
    return os.path.join(os.path.expanduser("~"), "Desktop")

def get_window_rect(hwnd):
    return win32gui.GetWindowRect(hwnd)

def is_point_inside_window(x, y, hwnd):
    if not hwnd:
        return False
    left, top, right, bottom = get_window_rect(hwnd)
    return left <= x <= right and top <= y <= bottom

# ================= MAIN =================
def main():
    # Selecionar janela
    janela_selecionada = selecionar_janela()
    if not janela_selecionada:
        print("Programa encerrado.")
        return
    
    hwnd = janela_selecionada['hwnd']
    titulo = janela_selecionada['titulo']
    print("\nJanela selecionada: '{}'".format(titulo))
    print("Gravacao iniciara quando voce clicar dentro da janela.")
    print("Pressione ESC a qualquer momento para interromper e salvar.")
    
    # Variaveis globais
    global recording, actions, start_time, program_running
    recording = False
    actions = []
    start_time = None
    program_running = True
    
    # ===== CALLBACKS =====
    def on_click(x, y, button, pressed):
        global recording, actions, start_time, hwnd
        if not pressed:
            return
        # Se não estiver gravando, verifica se o clique foi dentro da janela para iniciar
        if not recording:
            if is_point_inside_window(x, y, hwnd):
                recording = True
                start_time = time.time()
                print("\nGRAVACAO INICIADA.")
                # Registra o primeiro clique
                left, top, _, _ = get_window_rect(hwnd)
                rel_x = x - left
                rel_y = y - top
                action = {
                    'type': 'click',
                    'button': button.name,
                    'x': rel_x,
                    'y': rel_y,
                    'timestamp': 0.0
                }
                actions.append(action)
                print("Clique {} em ({}, {})".format(button.name, rel_x, rel_y))
            else:
                print("Clique fora da janela. Aguardando clique dentro para iniciar.")
            return
        
        # Se já estiver gravando, registra cliques dentro da janela
        if recording:
            if is_point_inside_window(x, y, hwnd):
                left, top, _, _ = get_window_rect(hwnd)
                rel_x = x - left
                rel_y = y - top
                action = {
                    'type': 'click',
                    'button': button.name,
                    'x': rel_x,
                    'y': rel_y,
                    'timestamp': time.time() - start_time
                }
                actions.append(action)
                print("Clique {} em ({}, {})".format(button.name, rel_x, rel_y))
            else:
                print("Clique fora da janela ignorado.")

    def on_press(key):
        global recording, program_running
        if key == STOP_KEY:
            print("Interrompendo pelo usuario...")
            program_running = False
            return False
        if recording:
            fg_hwnd = win32gui.GetForegroundWindow()
            if hwnd is not None and fg_hwnd == hwnd:
                try:
                    key_name = key.char
                except AttributeError:
                    key_name = str(key).replace('Key.', '')
                action = {
                    'type': 'key',
                    'key': key_name,
                    'timestamp': time.time() - start_time
                }
                actions.append(action)
                print("Tecla '{}' registrada".format(key_name))
            else:
                print("Tecla ignorada (janela nao em foco)")

    # Inicia listeners
    print("\nAguardando clique dentro da janela para iniciar a gravacao...")
    with mouse.Listener(on_click=on_click) as mouse_listener, \
         keyboard.Listener(on_press=on_press) as keyboard_listener:
        while program_running:
            # Verifica se a janela ainda existe
            if not win32gui.IsWindow(hwnd):
                print("Janela selecionada foi fechada. Encerrando...")
                recording = False
                break
            time.sleep(0.5)
        mouse_listener.stop()
        keyboard_listener.stop()

    # Salvar macro
    print("GRAVACAO FINALIZADA.")
    if actions:
        desktop = get_desktop_path()
        filename = os.path.join(desktop, "macro_{}.json".format(int(time.time())))
        with open(filename, 'w') as f:
            json.dump(actions, f, indent=2)
        print("Macro salva em {} com {} acoes.".format(filename, len(actions)))
    else:
        print("Nenhuma acao gravada.")

if __name__ == "__main__":
    main()
