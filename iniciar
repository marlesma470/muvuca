def ler_credencial_selic(descricao):
    """
    Lê o arquivo de credenciais e retorna o login e senha para a descrição fornecida.
    Exemplo de linha no arquivo:
        Selic SUL|2|Login|MARLON|Senha|Sicredi2026@
    """
    arquivo = os.path.join(
        os.environ["APPDATA"],
        "AutomacaoCustodia",
        "credenciais_sistemas.txt"
    )
    if not os.path.exists(arquivo):
        raise Exception(f"Arquivo não encontrado: {arquivo}")

    with open(arquivo, "r", encoding="utf-8", errors="ignore") as f:
        for linha in f:
            linha = linha.strip()
            if linha.startswith(descricao + "|"):
                partes = linha.split("|")
                # Espera-se: descricao, 2, Login, login, Senha, senha
                if len(partes) >= 6:
                    login = partes[3].strip()
                    senha = partes[5].strip()
                    return login, senha

    raise Exception(f"Credencial para '{descricao}' não encontrada.")

# -----------------------------------------------------------------------------
# FUNÇÃO PARA EXTRAIR O CÓDIGO DO E-MAIL (OUTLOOK)
# -----------------------------------------------------------------------------

def obter_codigo_email(tempo_espera=60, intervalo=3):
    """
    Aguarda até 'tempo_espera' segundos por um e-mail com assunto
    "Código Temporário SELIC" na Caixa de Entrada padrão.
    Extrai o código de 6 dígitos do corpo HTML.
    Retorna o código como string ou None se não encontrado.
    """
    outlook = win32com.client.Dispatch("Outlook.Application")
    namespace = outlook.GetNamespace("MAPI")
    inbox = namespace.GetDefaultFolder(6)  # olFolderInbox

    inicio = time.time()
    while time.time() - inicio < tempo_espera:
        items = inbox.Items
        items.Sort("[ReceivedTime]", True)
        for mail in items:
            try:
                assunto = str(mail.Subject).strip()
                if "Código Temporário SELIC" in assunto:
                    # Pega o corpo HTML (se disponível) ou corpo texto
                    corpo = mail.HTMLBody if hasattr(mail, 'HTMLBody') and mail.HTMLBody else mail.Body
                    # Procura por um número de 6 dígitos dentro de uma tag <p> com estilo
                    padrao = re.compile(r'<p[^>]*>(\d{6})</p>', re.IGNORECASE)
                    match = padrao.search(corpo)
                    if match:
                        codigo = match.group(1)
                        # Opcional: marcar como lido
                        mail.UnRead = False
                        mail.Save()
                        return codigo
            except Exception:
                continue
        time.sleep(intervalo)
    return None

