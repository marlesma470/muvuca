import json
import time
import subprocess
import os
import win32gui
import win32process
import psutil
from pynput import mouse, keyboard

# ================= CONFIGURACOES =================
STOP_KEY = keyboard.Key.esc

# ================= FUNCOES =================

def obter_caminho_executavel():
    print("\n" + "="*60)
    print("GRAVADOR DE MACROS UNIVERSAL")
    print("="*60)
    while True:
        exe_path = input("Caminho completo do executavel (ex: C:\\Programas\\MeuSistema.exe): ").strip()
        if exe_path and os.path.exists(exe_path):
            return exe_path
        print("Arquivo nao encontrado. Tente novamente.")

def get_desktop_path():
    return os.path.join(os.path.expanduser("~"), "Desktop")

def find_window_by_process(process_name):
    for proc in psutil.process_iter(['pid', 'name']):
        if proc.info['name'].lower() == process_name.lower():
            pid = proc.info['pid']
            def callback(hwnd, hwnds):
                if win32gui.IsWindowVisible(hwnd):
                    _, found_pid = win32process.GetWindowThreadProcessId(hwnd)
                    if found_pid == pid:
                        hwnds.append(hwnd)
                return True
            hwnds = []
            win32gui.EnumWindows(callback, hwnds)
            if hwnds:
                return hwnds[0]
    return None

def find_window_by_title(title):
    def callback(hwnd, hwnds):
        if win32gui.IsWindowVisible(hwnd):
            window_text = win32gui.GetWindowText(hwnd)
            if title.lower() in window_text.lower():
                hwnds.append(hwnd)
        return True
    hwnds = []
    win32gui.EnumWindows(callback, hwnds)
    return hwnds[0] if hwnds else None

def get_window_rect(hwnd):
    return win32gui.GetWindowRect(hwnd)

def is_point_inside_window(x, y, hwnd):
    if not hwnd:
        return False
    left, top, right, bottom = get_window_rect(hwnd)
    return left <= x <= right and top <= y <= bottom

def is_process_running(process_name):
    for proc in psutil.process_iter(['name']):
        if proc.info['name'].lower() == process_name.lower():
            return True
    return False

# ================= MAIN =================
def main():
    # Obter caminho do executavel
    exe_path = obter_caminho_executavel()
    process_name = os.path.basename(exe_path)
    window_title = os.path.splitext(process_name)[0]  # sem extensao, para fallback

    # Variaveis globais
    global recording, actions, start_time, hwnd, program_running
    recording = False
    actions = []
    start_time = None
    hwnd = None
    program_running = True

    # Abrir aplicativo
    try:
        print("Abrindo {} ...".format(exe_path))
        subprocess.Popen([exe_path])
        inicio = time.time()
        while True:
            hwnd = find_window_by_process(process_name)
            if hwnd:
                break
            if window_title:
                hwnd = find_window_by_title(window_title)
                if hwnd:
                    break
            if time.time() - inicio > 30:
                print("Tempo limite: aplicativo nao abriu.")
                return
            time.sleep(0.5)
        print("Janela encontrada.")
    except Exception as e:
        print("Erro: {}".format(e))
        return

    # Iniciar gravacao
    recording = True
    start_time = time.time()
    print("GRAVACAO INICIADA automaticamente.")
    print("Pressione ESC para interromper e salvar.")

    # ===== CALLBACKS =====
    def on_click(x, y, button, pressed):
        global recording, actions, start_time, hwnd
        if not recording or not pressed or hwnd is None:
            return
        if is_point_inside_window(x, y, hwnd):
            left, top, _, _ = get_window_rect(hwnd)
            rel_x = x - left
            rel_y = y - top
            action = {
                'type': 'click',
                'button': button.name,
                'x': rel_x,
                'y': rel_y,
                'timestamp': time.time() - start_time
            }
            actions.append(action)
            print("Clique {} em ({}, {})".format(button.name, rel_x, rel_y))
        else:
            print("Clique fora da janela ignorado.")

    def on_press(key):
        global recording, program_running
        if key == STOP_KEY:
            print("Interrompendo pelo usuario...")
            program_running = False
            return False
        if recording:
            fg_hwnd = win32gui.GetForegroundWindow()
            if hwnd is not None and fg_hwnd == hwnd:
                try:
                    key_name = key.char
                except AttributeError:
                    key_name = str(key).replace('Key.', '')
                action = {
                    'type': 'key',
                    'key': key_name,
                    'timestamp': time.time() - start_time
                }
                actions.append(action)
                print("Tecla '{}' registrada".format(key_name))
            else:
                print("Tecla ignorada (janela nao em foco)")

    # Listeners
    with mouse.Listener(on_click=on_click) as mouse_listener, \
         keyboard.Listener(on_press=on_press) as keyboard_listener:
        while program_running and recording:
            if not is_process_running(process_name):
                print("Aplicativo fechado. Encerrando...")
                recording = False
                break
            time.sleep(0.5)
        mouse_listener.stop()
        keyboard_listener.stop()

    # Salvar macro
    print("GRAVACAO FINALIZADA.")
    if actions:
        desktop = get_desktop_path()
        filename = os.path.join(desktop, "macro_{}.json".format(int(time.time())))
        with open(filename, 'w') as f:
            json.dump(actions, f, indent=2)
        print("Macro salva em {} com {} acoes.".format(filename, len(actions)))
    else:
        print("Nenhuma acao gravada.")

if __name__ == "__main__":
    main()
